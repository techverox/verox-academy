rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function loggedIn() {
      return request.auth != null;
    }

    // 1. SYSTEM & USERS
    match /systemConfig/{docId} { allow read: if true; allow write: if loggedIn(); }
    match /users/{userId} { 
      allow read: if loggedIn(); 
      allow write: if request.auth.uid == userId || (loggedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // 2. COURSES & LESSONS (Open Read for Stability)
    match /courses/{courseId} {
      allow read: if true;
      allow write: if loggedIn();
    }

    match /lessons/{lessonId} {
      allow read: if true;
      allow write: if loggedIn();
    }

    // 3. RESOURCES & QUIZZES
    match /resources/{resId} {
      allow read: if loggedIn();
      allow write: if loggedIn();
    }

    match /quizzes/{quizId} {
      allow read: if loggedIn();
      allow write: if loggedIn();
    }

    // 4. ANALYTICS & ENGAGEMENT
    match /lesson_analytics/{id} { allow read, write: if loggedIn(); }
    match /analytics_heatmaps/{id} { allow read, write: if loggedIn(); }
    match /analytics_lessons/{id} { allow read, write: if loggedIn(); }
    match /analytics_courses/{id} { allow read, write: if loggedIn(); }

    // 5. OTHER COLLECTIONS
    match /enrollments/{id} { allow read, write: if loggedIn(); }
    match /lessonProgress/{id} { allow read, write: if loggedIn(); }
    match /video_progress/{id} { allow read, write: if loggedIn(); }
    match /comments/{id} { allow read: if true; allow write: if loggedIn(); }
    match /comment_replies/{id} { allow read: if true; allow write: if loggedIn(); }
    match /comment_likes/{id} { allow read: if true; allow write: if loggedIn(); }
    match /video_reactions/{id} { allow read: if true; allow write: if loggedIn(); }
    match /reviews/{id} { allow read: if true; allow write: if loggedIn(); }
    match /teachers/{id} { allow read: if true; allow write: if loggedIn(); }
    match /certificates/{id} { allow read: if true; allow write: if loggedIn(); }
    match /payments/{id} { allow read: if loggedIn(); allow write: if loggedIn(); }
    match /creatorStats/{id} { allow read, write: if loggedIn(); }
    match /creatorApplications/{id} { allow read, write: if loggedIn(); }
    match /payoutRequests/{id} { allow read, write: if loggedIn(); }

    // Default catch-all
    match /{path=**} {
      allow read, write: if loggedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
