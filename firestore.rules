rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ─── HELPERS ──────────────────────────────────────────────────
    
    function loggedIn() {
      return request.auth != null;
    }

    function isMe(userId) {
      return loggedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return loggedIn() && (
        request.auth.token.admin == true ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'student') == 'admin')
      );
    }

    function isCreator() {
      return loggedIn() && (
        request.auth.token.creator == true ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'student') == 'creator')
      );
    }

    // ─── COLLECTION RULES ─────────────────────────────────────────
    
    // 1. SYSTEM CONFIG (Public)
    match /systemConfig/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 2. USERS (Self-managed)
    match /users/{userId} {
      allow read: if loggedIn(); // Allow all students to see creator profiles
      allow create, update: if isMe(userId);
      allow delete: if isAdmin();
    }

    // 3. COURSES (Secure visibility)
    match /courses/{courseId} {
      allow read: if (resource.data.published == true) || isAdmin() || (isCreator() && resource.data.creatorId == request.auth.uid);
      allow create: if isAdmin() || isCreator();
      allow update, delete: if isAdmin() || (isCreator() && resource.data.creatorId == request.auth.uid);
    }

    // 4. LESSONS (Enrolled students only)
    match /lessons/{lessonId} {
      allow read: if isAdmin() || (loggedIn() && (
        resource.data.get('isPreviewFree', false) == true || 
        exists(/databases/$(database)/documents/enrollments/$(request.auth.uid + "_" + resource.data.get('courseId', '')))
      ));
      allow write: if isAdmin() || (isCreator() && exists(/databases/$(database)/documents/courses/$(resource.data.get('courseId', ''))) && get(/databases/$(database)/documents/courses/$(resource.data.get('courseId', ''))).data.creatorId == request.auth.uid);
    }

    // 5. ENROLLMENTS (Private)
    match /enrollments/{enrollmentId} {
      allow read: if loggedIn() && (isAdmin() || request.auth.uid == resource.data.userId);
      allow create, update, delete: if isAdmin();
    }

    match /lessonProgress/{progressId} {
      allow read: if loggedIn() && (isAdmin() || request.auth.uid == resource.data.userId);
      allow create, update: if loggedIn() && (request.auth.uid == request.resource.data.userId);
      allow delete: if isAdmin();
    }
    
    match /video_progress/{progressId} {
      allow read: if loggedIn() && (isAdmin() || request.auth.uid == resource.data.userId);
      allow create, update: if loggedIn() && (request.auth.uid == request.resource.data.userId);
      allow delete: if isAdmin();
    }

    // 6. ENGAGEMENT (Comments, Reactions)
    match /comments/{commentId} {
      allow read: if true; // Discussions are usually public or semi-public
      allow create, update, delete: if loggedIn();
    }

    match /comment_replies/{replyId} {
      allow read: if true;
      allow create, update, delete: if loggedIn();
    }

    match /comment_likes/{likeId} {
      allow read: if true;
      allow create, delete: if loggedIn();
    }

    match /video_reactions/{reactionId} {
      allow read: if true;
      allow create, update, delete: if loggedIn();
    }

    // 7. PUBLIC INFRASTRUCTURE
    match /reviews/{reviewId} {
      allow read: if true;
      allow create, update: if loggedIn();
      allow delete: if isAdmin();
    }

    match /teachers/{teacherId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /certificates/{certId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Default: Deny all
    match /{path=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
