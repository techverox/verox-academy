rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ──────────────────────────────────────────────────────────────
    // HELPER FUNCTIONS
    // ──────────────────────────────────────────────────────────────
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // UPGRADED: Uses Firebase Custom Claims instead of Firestore reads.
    // This eliminates an expensive Firestore get() on every admin operation.
    // Custom claims are set via /api/admin/set-claims endpoint.
    // Fallback: Also checks Firestore profile role for backward compatibility.
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.admin == true ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'student') == 'admin')
      );
    }

    function isCreator() {
      return isAuthenticated() && (
        request.auth.token.creator == true ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'student') == 'creator')
      );
    }

    // Check if a user is enrolled in a specific course
    function isEnrolledInCourse(userId, courseId) {
      return exists(/databases/$(database)/documents/enrollments/$(userId + "_" + courseId));
    }

    function isCourseOwner(courseId) {
      return isAdmin() || (isCreator() && get(/databases/$(database)/documents/courses/$(courseId)).data.creatorId == request.auth.uid);
    }

    // ──────────────────────────────────────────────────────────────
    // COLLECTION RULES
    // ──────────────────────────────────────────────────────────────

    // USERS
    match /users/{userId} {
      // Public profiles
      allow read: if true;
      // Users can create/update their own profile
      allow create, update: if isOwner(userId);
      // Only admins can delete users
      allow delete: if isAdmin();
      // Admin can list all users
      allow list: if isAdmin();
    }

    // COURSES
    match /courses/{courseId} {
      // Public can read published courses. Admin/Creator can read all.
      allow read: if (resource.data.published == true) || 
                     isAdmin() || 
                     (isCreator() && resource.data.creatorId == request.auth.uid) ||
                     (isAuthenticated() && isEnrolledInCourse(request.auth.uid, courseId));
      // Admins can write all. Creators can write their own.
      allow create: if isAdmin() || isCreator();
      allow update, delete: if isAdmin() || (isCreator() && resource.data.creatorId == request.auth.uid);
    }

    // LESSONS
    match /lessons/{lessonId} {
      allow read: if isAdmin() || 
                     (isAuthenticated() && 
                      resource.data.courseId != null && 
                      (isEnrolledInCourse(request.auth.uid, resource.data.courseId) ||
                       isCourseOwner(resource.data.courseId))) ||
                     (resource.data.isPreviewFree == true);
      allow create: if isAdmin() || (isCreator() && request.resource.data.courseId != null && get(/databases/$(database)/documents/courses/$(request.resource.data.courseId)).data.creatorId == request.auth.uid);
      allow update, delete: if isAdmin() || (isCreator() && resource.data.courseId != null && get(/databases/$(database)/documents/courses/$(resource.data.courseId)).data.creatorId == request.auth.uid);
    }

    // ENROLLMENTS
    match /enrollments/{enrollmentId} {
      // Users read own, admins read all, creators read for their courses
      allow read: if isAuthenticated() && (
        request.auth.uid == enrollmentId.split('_')[0] || 
        (resource != null && (request.auth.uid == resource.data.userId || get(/databases/$(database)/documents/courses/$(resource.data.courseId)).data.creatorId == request.auth.uid)) || 
        isAdmin()
      );
      allow create: if isAdmin(); // Server-side only
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // LESSON PROGRESS
    match /lessonProgress/{progressId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == progressId.split('_')[0] || 
        (resource != null && (request.auth.uid == resource.data.userId || get(/databases/$(database)/documents/courses/$(resource.data.courseId)).data.creatorId == request.auth.uid)) || 
        isAdmin()
      );
      allow create: if isAuthenticated() && (request.auth.uid == request.resource.data.userId);
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // PAYMENTS
    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (
        (resource != null && (request.auth.uid == resource.data.userId || resource.data.creatorId == request.auth.uid)) || 
        isAdmin()
      );
      allow write: if false; // Server-side only
    }

    // CREATOR APPLICATIONS
    match /creatorApplications/{appId} {
      allow read: if isAdmin() || (isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid));
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // PAYOUT REQUESTS
    match /payoutRequests/{requestId} {
      allow read: if isAdmin() || (isCreator() && (resource == null || resource.data.creatorId == request.auth.uid));
      allow create: if isCreator() && request.resource.data.creatorId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // PLATFORM STATS
    match /platformStats/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // CREATOR STATS
    match /creatorStats/{creatorId} {
      allow read: if isAdmin() || (isCreator() && request.auth.uid == creatorId);
      allow write: if false;
    }

    // COURSE STATS
    match /courseStats/{courseId} {
      allow read: if isAdmin() || (isCreator() && get(/databases/$(database)/documents/courses/$(courseId)).data.creatorId == request.auth.uid);
      allow write: if false;
    }

    // ADMIN AUDIT LOG
    match /adminAuditLog/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // CERTIFICATES
    match /certificates/{certId} {
      allow read: if true; // Public verification allowed
      allow write: if false; // Server-side only
    }

    // RESOURCES
    match /resources/{resourceId} {
      allow read: if isAdmin() || 
                     (isAuthenticated() && 
                      (isEnrolledInCourse(request.auth.uid, resource.data.courseId) ||
                       isCourseOwner(resource.data.courseId)));
      allow create: if isAdmin() || (isCreator() && get(/databases/$(database)/documents/courses/$(request.resource.data.courseId)).data.creatorId == request.auth.uid);
      allow update, delete: if isAdmin() || (isCreator() && get(/databases/$(database)/documents/courses/$(resource.data.courseId)).data.creatorId == request.auth.uid);
    }
  }
}
