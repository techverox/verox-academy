rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ──────────────────────────────────────────────────────────────
    // HELPER FUNCTIONS
    // ──────────────────────────────────────────────────────────────
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // UPGRADED: Uses Firebase Custom Claims instead of Firestore reads.
    // This eliminates an expensive Firestore get() on every admin operation.
    // Custom claims are set via /api/admin/set-claims endpoint.
    // Fallback: Also checks Firestore profile role for backward compatibility.
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.admin == true ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'student') == 'admin')
      );
    }

    // Check if a user is enrolled in a specific course
    function isEnrolledInCourse(userId, courseId) {
      return exists(/databases/$(database)/documents/enrollments/$(userId + "_" + courseId));
    }

    // ──────────────────────────────────────────────────────────────
    // COLLECTION RULES
    // ──────────────────────────────────────────────────────────────

    // USERS
    match /users/{userId} {
      // Public profiles (read-only for name, photo, etc.)
      allow read: if true;
      // Users can create/update their own profile
      allow create, update: if isOwner(userId);
      // Only admins can delete users
      allow delete: if isAdmin();
      // Admin can list all users
      allow list: if isAdmin();
    }

    // COURSES
    match /courses/{courseId} {
      // Public can read published courses. Admin can read all.
      // Enrolled students can also read unpublished courses (for ongoing access).
      allow read: if (resource.data.published == true) || 
                     isAdmin() || 
                     (isAuthenticated() && isEnrolledInCourse(request.auth.uid, courseId));
      // Only admins can create/update/delete courses
      allow write: if isAdmin();
    }

    // LESSONS
    // SECURITY: Lessons are no longer publicly readable.
    // Only enrolled users, admins, or users viewing free preview lessons can read.
    match /lessons/{lessonId} {
      allow read: if isAdmin() || 
                     (isAuthenticated() && 
                      resource.data.courseId != null && 
                      isEnrolledInCourse(request.auth.uid, resource.data.courseId)) ||
                     (resource.data.isPreviewFree == true);
      allow write: if isAdmin();
    }

    // ENROLLMENTS
    // SECURITY: Enrollments can only be created server-side (via webhook/verify API).
    // Client-side enrollment creation is blocked.
    match /enrollments/{enrollmentId} {
      // Users can read their own enrollments, admins can read all
      allow read: if isAuthenticated() && (
        request.auth.uid == enrollmentId.split('_')[0] || 
        (resource != null && request.auth.uid == resource.data.userId) || 
        isAdmin()
      );
      // SECURITY: Only server-side (admin SDK) can create enrollments.
      // This prevents the free enrollment bypass vulnerability.
      allow create: if isAdmin();
      // Users can update their own enrollment progress
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // LESSON PROGRESS
    match /lessonProgress/{progressId} {
      // Users can read their own progress
      allow read: if isAuthenticated() && (
        request.auth.uid == progressId.split('_')[0] || 
        (resource != null && request.auth.uid == resource.data.userId) || 
        isAdmin()
      );
      // Users can create/update their own progress
      allow create: if isAuthenticated() && (request.auth.uid == request.resource.data.userId);
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // PAYMENTS
    // SECURITY: Payment records are server-write only.
    // Clients can read their own payment records for display purposes.
    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (
        (resource != null && request.auth.uid == resource.data.userId) || 
        isAdmin()
      );
      // No client-side writes allowed — payments are created by API routes only
      allow write: if false;
    }

    // PLATFORM STATS (Aggregation Collection)
    // Server-write only. Anyone authenticated can read (for dashboard).
    match /platformStats/{docId} {
      allow read: if isAdmin();
      allow write: if false; // Server-side only (Admin SDK)
    }

    // COURSE STATS (Aggregation Collection)
    // Server-write only. Admins can read.
    match /courseStats/{courseId} {
      allow read: if isAdmin();
      allow write: if false; // Server-side only (Admin SDK)
    }

    // ADMIN AUDIT LOG
    // Server-write only. Admins can read for audit purposes.
    match /adminAuditLog/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Server-side only (Admin SDK)
    }
  }
}
